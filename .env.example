# Local dev example (DO NOT commit real secrets)
# Copy to .env for local development.

# Django
SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Render (optional for local)
# RENDER_EXTERNAL_HOSTNAME=your-service.onrender.com

# Database (Render will set DATABASE_URL when you attach Postgres)
# DATABASE_URL=postgres://...

# Optional
# CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com

# Adminpanel (optional)
PRIVATE_ADMIN_EMAIL=
PRIVATE_ADMIN_PASSWORD=

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
