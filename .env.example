# Local dev example (DO NOT commit real secrets)
# Copy to .env for local development.

# Django
SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Railway (set in Railway Variables)
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# RAILWAY_URL=https://your-app.up.railway.app

# Render (optional for local)
# RENDER_EXTERNAL_HOSTNAME=your-service.onrender.com

# Database (Render will set DATABASE_URL when you attach Postgres)
# DATABASE_URL=postgres://...

# Optional
# CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com

# Production recommendations
# DEBUG=0
# SECURE_SSL_REDIRECT=1

# Adminpanel (optional)
PRIVATE_ADMIN_EMAIL=
PRIVATE_ADMIN_PASSWORD=

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
